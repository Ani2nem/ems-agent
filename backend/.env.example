# Local dev config. Copy to .env (gitignored) or export directly.

# false => graceful mock fallback, zero Bedrock/AWS calls (default for local dev)
USE_BEDROCK=false

# Bedrock model id used by all agents in v1 (swappable per-agent later)
MODEL_ID=amazon.nova-micro-v1:0

# AWS region where Bedrock model access is enabled
AWS_REGION=us-east-1

# DynamoDB table name (set by SAM in prod; unused in mock mode)
JOBS_TABLE=ems-agent-jobs

# Step Functions ARN (set by SAM in prod; local submit runs the negotiation inline in mock mode)
STATE_MACHINE_ARN=

# Escalation email (optional; only used when ENABLE_SES_EMAIL=true)
ENABLE_SES_EMAIL=false
ESCALATION_EMAIL=

# Seconds between negotiation states in local/mock mode, so the frontend poll
# loop can actually show the back-and-forth. 0 = instant (tests force this).
LOCAL_STEP_DELAY_SECONDS=2
